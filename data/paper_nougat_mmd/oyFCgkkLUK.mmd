\[\begin{split}&\mathbb{E}[P_{[y]}(C_{i})\wedge P_{[y]}(C_{j})] \geq P_{[y]}(C_{i}\cup C_{j})\\ &\iff\frac{|C_{i}|_{y}P_{y}(C_{i})+|C_{j}|_{y}P_{y}(C_{j})}{|C_{i} |_{y}+|C_{j}|_{y}}\geq P_{y}(C_{i}\cup C_{j})\\ &\iff\frac{|C_{i}|_{y}\frac{|C_{i}|_{y}}{|C_{i}|}+|C_{j}|_{y} \frac{|C_{i}|_{y}}{|C_{j}|}}{|C_{i}|_{y}+|C_{j}|_{y}}\geq\frac{|C_{i}|_{y}+|C_{ j}|_{y}}{|C_{i}|+|C_{j}|}\\ &\iff\frac{\frac{|C_{i}|_{x}^{2}}{|C_{i}|}+\frac{|C_{i}|_{x}^{2} }{|C_{i}|}}{|C_{i}|_{y}+|C_{j}|_{y}}-\frac{|C_{i}|_{y}+|C_{j}|_{y}}{|C_{i}|+|C _{j}|}\geq 0\\ &\iff\frac{|C_{j}||C_{i}|_{y}^{2}+|C_{i}||C_{j}|_{y}^{2}}{|C_{i} ||C_{j}|(|C_{i}|_{y}+|C_{j}|_{y})}-\frac{|C_{i}|_{y}+|C_{j}|_{y}}{|C_{i}|+|C_{ j}|}\geq 0\\ &\iff\frac{(|C_{i}||C_{j}|_{y}-|C_{j}||C_{i}|_{y})^{2}}{|C_{i}|_{ j}|(|C_{i}|_{y}+|C_{j}|_{y})(|C_{i}|+|C_{j}|)}\geq 0\\ &\iff(|C_{i}||C_{j}|_{y}-|C_{j}||C_{i}|_{y})^{2}\geq 0\iff \top\end{split} \tag{10}\]

